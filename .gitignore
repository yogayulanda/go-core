# Binaries for programs and plugins
bin/
dist/
build/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage/
coverage.*
*.coverprofile

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# Environment files
.env
.env.*
!.env.example

# Local assistant/context artifacts
.ai/
.claude/
AI_RULES.md
AGENTS.md
CONTEXT.md
PROJECT_CONTEXT.md

# Forge context scratch/generated outputs
.forge/context/temp/
!.forge/context/temp/.gitkeep
.forge/context/generated/*
!.forge/context/generated/.gitkeep

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor swap/backup
*.swp
*.swo
*~
*.bak
*.orig

# IDEs
.idea/
.vscode/
*.iml

# Local cache & logs
*.log
*.tmp
.cache/
tmp/
temp/

# Local secret/certificate material
*.pem
*.key
*.crt
*.p12
*.jks

# Accidentally compiled binaries without extensions (if they match package names)
httpclient_example
bootstrap_example
db_logging_example
grpc_handler_example
outbox_example
pagination_example
repository_example
service_example
service_logging_example
transaction_logging_example
